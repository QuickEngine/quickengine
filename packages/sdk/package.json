{
	"name": "@quickengine/quick",
	"version": "0.1.0",
	"description": "Quick.js TypeScript client for QuickEngine and QuickDash",
	"private": true,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format cjs,esm --dts",
		"dev": "tsup src/index.ts --format cjs,esm --dts --watch",
		"clean": "rm -rf dist",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"devDependencies": {
		"@quickengine/config": "workspace:*",
		"tsup": "^8.4.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"quickengine",
		"quickdash",
		"quick.js",
		"sdk",
		"api"
	],
	"license": "MIT",
	"author": "QuickEngine Software"
}
