{
	"name": "quickengine",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.28.1",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "turbo dev",
		"dev:quickengine": "turbo dev --filter=@quickengine/web --filter=@quickengine/admin",
		"prepare": "husky",
		"build": "turbo build",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "biome check .",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"ci:local": "act push",
		"ci:local:ci": "act push --workflows .github/workflows/ci.yml",
		"ci:local:release": "act push --workflows .github/workflows/release.yml",
		"ci:local:secrets": "act push --workflows .github/workflows/secrets-scan.yml",
		"db:generate": "pnpm --filter @quickengine/db db:generate",
		"db:migrate": "pnpm --filter @quickengine/db db:migrate",
		"db:push": "pnpm --filter @quickengine/db db:push",
		"db:studio": "pnpm --filter @quickengine/db db:studio",
		"docker:up": "docker compose -f docker/docker-compose.yml up -d",
		"docker:down": "docker compose -f docker/docker-compose.yml down",
		"docker:reset": "docker compose -f docker/docker-compose.yml down -v && docker compose -f docker/docker-compose.yml up -d"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/node": "^26.1.0",
		"dotenv": "^17.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"turbo": "^2.10.0",
		"typescript": "6.0.3"
	}
}
