# QuickEngine Software local development
DATABASE_URL="postgresql://quickengine:quickengine_dev_password@localhost:5435/quickengine"
# Cost guardrail: set "true" ONLY on the production env, paired with the prod
# DATABASE_URL. Blocks preview/dev deploys from booting against prod. See
# docs/COST_GUARDRAILS.md. Leave unset locally.
DATABASE_IS_PRODUCTION=""
REDIS_URL="redis://localhost:6381"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
NODE_ENV="development"

# Better Auth
BETTER_AUTH_SECRET="00000000000000000000000000000000"
BETTER_AUTH_URL="http://localhost:3002"
# Prod only: parent domain for cross-subdomain session cookies (e.g. ".quickengine.xyz").
# Leave empty locally and on *.vercel.app (cookies can't span vercel.app subdomains).
AUTH_COOKIE_DOMAIN=""
NEXT_PUBLIC_QUICKENGINE_AUTH_URL="http://localhost:3002"
INITIAL_ADMIN_EMAILS=""

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# App URLs
NEXT_PUBLIC_QUICKENGINE_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_QUICKENGINE_ACCOUNT_URL="http://localhost:3001"
NEXT_PUBLIC_QUICKDASH_WEB_URL="http://localhost:3010"
NEXT_PUBLIC_QUICKDASH_ADMIN_URL="http://localhost:3011"

# Email
RESEND_API_KEY=""
# Outbound sender on a Resend-verified domain (prod). Unset falls back to
# onboarding@resend.dev, which only delivers to the Resend account owner.
EMAIL_FROM=""
RESEND_WEBHOOK_SECRET=""

# Jobs
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Storage
BLOB_READ_WRITE_TOKEN=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_URL=""

# Search
ALGOLIA_APP_ID=""
ALGOLIA_SEARCH_KEY=""
ALGOLIA_ADMIN_KEY=""

# Realtime
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Per-plan Stripe price IDs (price_...). Convention: STRIPE_PRICE_<PLAN>_<CYCLE>.
# Tier names are placeholders and amounts live in Stripe; leave unset until priced.
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_GROWTH_MONTHLY=""
STRIPE_PRICE_GROWTH_ANNUAL=""
STRIPE_PRICE_TEAM_MONTHLY=""
STRIPE_PRICE_TEAM_ANNUAL=""
# Superseded by STRIPE_PRICE_* above; kept for reference.
STRIPE_QUICKENGINE_SUITE_MONTHLY_PRICE_ID=""
